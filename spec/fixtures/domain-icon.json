{
  "description": "Maps an entity_id to a single-glyph domain icon. The domain is the substring before the first '.'. Unknown domains fall back to '○'.",
  "function": "domainIcon",
  "fallback": "○",
  "cases": [
    { "input": "light.living_room", "expect": "◆" },
    { "input": "switch.kitchen", "expect": "⏻" },
    { "input": "sensor.temperature", "expect": "◉" },
    { "input": "binary_sensor.motion", "expect": "◎" },
    { "input": "climate.thermostat", "expect": "⊕" },
    { "input": "cover.garage", "expect": "▫" },
    { "input": "fan.bedroom", "expect": "✦" },
    { "input": "media_player.tv", "expect": "♫" },
    { "input": "automation.morning", "expect": "⚙" },
    { "input": "script.welcome", "expect": "▶" },
    { "input": "scene.movie", "expect": "✦" },
    { "input": "person.alice", "expect": "◈" },
    { "input": "device_tracker.phone", "expect": "◈" },
    { "input": "camera.front", "expect": "⊡" },
    { "input": "lock.front_door", "expect": "⊠" },
    { "input": "vacuum.roomba", "expect": "◌" },
    { "input": "alarm_control_panel.home", "expect": "⊗" },
    { "input": "weather.home", "expect": "☁" },
    { "input": "button.restart", "expect": "▣" },
    { "input": "input_button.test", "expect": "▣" },
    { "input": "number.threshold", "expect": "#" },
    { "input": "input_number.level", "expect": "#" },
    { "input": "select.mode", "expect": "≡" },
    { "input": "input_select.scene", "expect": "≡" },
    { "input": "input_boolean.guest", "expect": "⏻" },
    { "input": "input_text.note", "expect": "T" },
    { "input": "input_datetime.alarm", "expect": "⊙" },
    { "input": "sun.sun", "expect": "☀" },
    { "input": "zone.home", "expect": "⬡" },
    { "input": "update.firmware", "expect": "↑" },
    { "input": "calendar.events", "expect": "▦" },
    { "input": "timer.kitchen", "expect": "⊘" },
    { "input": "counter.visits", "expect": "+" },
    { "input": "group.all_lights", "expect": "⊞" },
    { "input": "unknown_domain.entity", "expect": "○" },
    { "input": "custom.thing", "expect": "○" },
    { "input": "sensor.my.nested.entity", "expect": "◉" }
  ]
}
