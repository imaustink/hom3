{
  "description": "Deterministic service-call computation in the HA client layer. Given an entity's current state/attributes and the user action, the implementation must produce the exact Home Assistant service call(s) shown. 'expectCall' is the single resulting call (or null for no-op). 'expectCalls' is an ordered list (bulk operations). 'expectReturn' asserts the method's return value where meaningful. The seeded 'entity' (when present) is loaded into the client's entity store before the call.",
  "cases": [
    { "name": "toggle light", "method": "toggleEntity", "args": ["light.x"], "expectCall": { "domain": "light", "service": "toggle", "service_data": { "entity_id": "light.x" } } },
    { "name": "toggle switch", "method": "toggleEntity", "args": ["switch.x"], "expectCall": { "domain": "switch", "service": "toggle", "service_data": { "entity_id": "switch.x" } } },
    { "name": "toggle sensor is no-op", "method": "toggleEntity", "args": ["sensor.x"], "expectCall": null },

    { "name": "activate light -> toggle", "method": "activateEntity", "args": ["light.x"], "expectCall": { "domain": "light", "service": "toggle", "service_data": { "entity_id": "light.x" } }, "expectReturn": true },
    { "name": "activate button -> press", "method": "activateEntity", "args": ["button.x"], "expectCall": { "domain": "button", "service": "press", "service_data": { "entity_id": "button.x" } }, "expectReturn": true },
    { "name": "activate input_button -> press", "method": "activateEntity", "args": ["input_button.x"], "expectCall": { "domain": "input_button", "service": "press", "service_data": { "entity_id": "input_button.x" } }, "expectReturn": true },
    { "name": "activate scene -> turn_on", "method": "activateEntity", "args": ["scene.x"], "expectCall": { "domain": "scene", "service": "turn_on", "service_data": { "entity_id": "scene.x" } }, "expectReturn": true },
    { "name": "activate script when on -> turn_off", "method": "activateEntity", "args": ["script.x"], "entity": { "entity_id": "script.x", "state": "on", "attributes": {} }, "expectCall": { "domain": "script", "service": "turn_off", "service_data": { "entity_id": "script.x" } }, "expectReturn": true },
    { "name": "activate script when off -> turn_on", "method": "activateEntity", "args": ["script.x"], "entity": { "entity_id": "script.x", "state": "off", "attributes": {} }, "expectCall": { "domain": "script", "service": "turn_on", "service_data": { "entity_id": "script.x" } }, "expectReturn": true },
    { "name": "activate vacuum cleaning -> stop", "method": "activateEntity", "args": ["vacuum.x"], "entity": { "entity_id": "vacuum.x", "state": "cleaning", "attributes": {} }, "expectCall": { "domain": "vacuum", "service": "stop", "service_data": { "entity_id": "vacuum.x" } }, "expectReturn": true },
    { "name": "activate vacuum docked -> start", "method": "activateEntity", "args": ["vacuum.x"], "entity": { "entity_id": "vacuum.x", "state": "docked", "attributes": {} }, "expectCall": { "domain": "vacuum", "service": "start", "service_data": { "entity_id": "vacuum.x" } }, "expectReturn": true },
    { "name": "activate sensor is no-op", "method": "activateEntity", "args": ["sensor.x"], "expectCall": null, "expectReturn": false },

    { "name": "brightness up from 100 by 26", "method": "adjustBrightness", "args": ["light.x", 26], "entity": { "entity_id": "light.x", "state": "on", "attributes": { "brightness": 100 } }, "expectCall": { "domain": "light", "service": "turn_on", "service_data": { "entity_id": "light.x", "brightness": 126 } }, "expectReturn": true },
    { "name": "brightness down while off is blocked", "method": "adjustBrightness", "args": ["light.x", -26], "entity": { "entity_id": "light.x", "state": "off", "attributes": {} }, "expectCall": null, "expectReturn": false },
    { "name": "brightness up while off uses default 128", "method": "adjustBrightness", "args": ["light.x", 26], "entity": { "entity_id": "light.x", "state": "off", "attributes": {} }, "expectCall": { "domain": "light", "service": "turn_on", "service_data": { "entity_id": "light.x", "brightness": 154 } }, "expectReturn": true },
    { "name": "brightness up with no attr uses default 128", "method": "adjustBrightness", "args": ["light.x", 26], "entity": { "entity_id": "light.x", "state": "on", "attributes": {} }, "expectCall": { "domain": "light", "service": "turn_on", "service_data": { "entity_id": "light.x", "brightness": 154 } }, "expectReturn": true },
    { "name": "brightness clamps to 255", "method": "adjustBrightness", "args": ["light.x", 26], "entity": { "entity_id": "light.x", "state": "on", "attributes": { "brightness": 250 } }, "expectCall": { "domain": "light", "service": "turn_on", "service_data": { "entity_id": "light.x", "brightness": 255 } }, "expectReturn": true },

    { "name": "temp up by 0.5", "method": "adjustTemperature", "args": ["climate.x", 0.5], "entity": { "entity_id": "climate.x", "state": "heat", "attributes": { "temperature": 20 } }, "expectCall": { "domain": "climate", "service": "set_temperature", "service_data": { "entity_id": "climate.x", "temperature": 20.5 } } },
    { "name": "temp down by 0.5", "method": "adjustTemperature", "args": ["climate.x", -0.5], "entity": { "entity_id": "climate.x", "state": "heat", "attributes": { "temperature": 20 } }, "expectCall": { "domain": "climate", "service": "set_temperature", "service_data": { "entity_id": "climate.x", "temperature": 19.5 } } },
    { "name": "temp default 20 when missing", "method": "adjustTemperature", "args": ["climate.x", 0.5], "entity": { "entity_id": "climate.x", "state": "heat", "attributes": {} }, "expectCall": { "domain": "climate", "service": "set_temperature", "service_data": { "entity_id": "climate.x", "temperature": 20.5 } } },
    { "name": "temp rounds to nearest 0.5", "method": "adjustTemperature", "args": ["climate.x", 0.5], "entity": { "entity_id": "climate.x", "state": "heat", "attributes": { "temperature": 21.3 } }, "expectCall": { "domain": "climate", "service": "set_temperature", "service_data": { "entity_id": "climate.x", "temperature": 22 } } },

    { "name": "hvac cycle heat -> cool", "method": "cycleHvacMode", "args": ["climate.x"], "entity": { "entity_id": "climate.x", "state": "heat", "attributes": { "hvac_modes": ["off", "heat", "cool"] } }, "expectCall": { "domain": "climate", "service": "set_hvac_mode", "service_data": { "entity_id": "climate.x", "hvac_mode": "cool" } } },
    { "name": "hvac cycle wraps cool -> off", "method": "cycleHvacMode", "args": ["climate.x"], "entity": { "entity_id": "climate.x", "state": "cool", "attributes": { "hvac_modes": ["off", "heat", "cool"] } }, "expectCall": { "domain": "climate", "service": "set_hvac_mode", "service_data": { "entity_id": "climate.x", "hvac_mode": "off" } } },
    { "name": "hvac cycle off -> heat", "method": "cycleHvacMode", "args": ["climate.x"], "entity": { "entity_id": "climate.x", "state": "off", "attributes": { "hvac_modes": ["off", "heat", "cool"] } }, "expectCall": { "domain": "climate", "service": "set_hvac_mode", "service_data": { "entity_id": "climate.x", "hvac_mode": "heat" } } },
    { "name": "hvac single mode is no-op", "method": "cycleHvacMode", "args": ["climate.x"], "entity": { "entity_id": "climate.x", "state": "heat", "attributes": { "hvac_modes": ["heat"] } }, "expectCall": null },

    { "name": "cover open", "method": "controlCover", "args": ["cover.x", "open_cover"], "expectCall": { "domain": "cover", "service": "open_cover", "service_data": { "entity_id": "cover.x" } } },
    { "name": "cover close", "method": "controlCover", "args": ["cover.x", "close_cover"], "expectCall": { "domain": "cover", "service": "close_cover", "service_data": { "entity_id": "cover.x" } } },
    { "name": "cover stop", "method": "controlCover", "args": ["cover.x", "stop_cover"], "expectCall": { "domain": "cover", "service": "stop_cover", "service_data": { "entity_id": "cover.x" } } },

    { "name": "fan up snaps to step grid", "method": "adjustFanSpeed", "args": ["fan.x", 1], "entity": { "entity_id": "fan.x", "state": "on", "attributes": { "percentage": 50, "percentage_step": 25 } }, "expectCall": { "domain": "fan", "service": "set_percentage", "service_data": { "entity_id": "fan.x", "percentage": 75 } }, "expectReturn": 75 },
    { "name": "fan down", "method": "adjustFanSpeed", "args": ["fan.x", -1], "entity": { "entity_id": "fan.x", "state": "on", "attributes": { "percentage": 50, "percentage_step": 25 } }, "expectCall": { "domain": "fan", "service": "set_percentage", "service_data": { "entity_id": "fan.x", "percentage": 25 } }, "expectReturn": 25 },
    { "name": "fan down to zero turns off", "method": "adjustFanSpeed", "args": ["fan.x", -1], "entity": { "entity_id": "fan.x", "state": "on", "attributes": { "percentage": 25, "percentage_step": 25 } }, "expectCall": { "domain": "fan", "service": "turn_off", "service_data": { "entity_id": "fan.x" } }, "expectReturn": 0 },
    { "name": "fan down while off is blocked", "method": "adjustFanSpeed", "args": ["fan.x", -1], "entity": { "entity_id": "fan.x", "state": "off", "attributes": {} }, "expectCall": null, "expectReturn": null },
    { "name": "fan up with default step 25", "method": "adjustFanSpeed", "args": ["fan.x", 1], "entity": { "entity_id": "fan.x", "state": "on", "attributes": {} }, "expectCall": { "domain": "fan", "service": "set_percentage", "service_data": { "entity_id": "fan.x", "percentage": 25 } }, "expectReturn": 25 },
    { "name": "fan up clamps to 100", "method": "adjustFanSpeed", "args": ["fan.x", 1], "entity": { "entity_id": "fan.x", "state": "on", "attributes": { "percentage": 90, "percentage_step": 25 } }, "expectCall": { "domain": "fan", "service": "set_percentage", "service_data": { "entity_id": "fan.x", "percentage": 100 } }, "expectReturn": 100 },

    { "name": "volume up by 0.1", "method": "adjustVolume", "args": ["media_player.x", 0.1], "entity": { "entity_id": "media_player.x", "state": "playing", "attributes": { "volume_level": 0.5 } }, "expectCall": { "domain": "media_player", "service": "volume_set", "service_data": { "entity_id": "media_player.x", "volume_level": 0.6 } } },
    { "name": "volume clamps to 1", "method": "adjustVolume", "args": ["media_player.x", 0.1], "entity": { "entity_id": "media_player.x", "state": "playing", "attributes": { "volume_level": 0.95 } }, "expectCall": { "domain": "media_player", "service": "volume_set", "service_data": { "entity_id": "media_player.x", "volume_level": 1 } } },
    { "name": "volume default 0.5 when missing", "method": "adjustVolume", "args": ["media_player.x", 0.1], "entity": { "entity_id": "media_player.x", "state": "playing", "attributes": {} }, "expectCall": { "domain": "media_player", "service": "volume_set", "service_data": { "entity_id": "media_player.x", "volume_level": 0.6 } } },
    { "name": "volume clamps to 0", "method": "adjustVolume", "args": ["media_player.x", -0.1], "entity": { "entity_id": "media_player.x", "state": "playing", "attributes": { "volume_level": 0.05 } }, "expectCall": { "domain": "media_player", "service": "volume_set", "service_data": { "entity_id": "media_player.x", "volume_level": 0 } } },

    { "name": "media next track", "method": "mediaPlayerCommand", "args": ["media_player.x", "media_next_track"], "expectCall": { "domain": "media_player", "service": "media_next_track", "service_data": { "entity_id": "media_player.x" } } },
    { "name": "media previous track", "method": "mediaPlayerCommand", "args": ["media_player.x", "media_previous_track"], "expectCall": { "domain": "media_player", "service": "media_previous_track", "service_data": { "entity_id": "media_player.x" } } },

    { "name": "vacuum start", "method": "vacuumCommand", "args": ["vacuum.x", "start"], "expectCall": { "domain": "vacuum", "service": "start", "service_data": { "entity_id": "vacuum.x" } } },
    { "name": "vacuum return to base", "method": "vacuumCommand", "args": ["vacuum.x", "return_to_base"], "expectCall": { "domain": "vacuum", "service": "return_to_base", "service_data": { "entity_id": "vacuum.x" } } },

    { "name": "alarm arm away (no code)", "method": "alarmControl", "args": ["alarm_control_panel.x", "alarm_arm_away"], "expectCall": { "domain": "alarm_control_panel", "service": "alarm_arm_away", "service_data": { "entity_id": "alarm_control_panel.x" } } },
    { "name": "alarm disarm with code", "method": "alarmControl", "args": ["alarm_control_panel.x", "alarm_disarm", "1234"], "expectCall": { "domain": "alarm_control_panel", "service": "alarm_disarm", "service_data": { "entity_id": "alarm_control_panel.x", "code": "1234" } } },

    { "name": "number up by step within range", "method": "adjustNumber", "args": ["number.x", 1], "entity": { "entity_id": "number.x", "state": "5", "attributes": { "step": 1, "min": 0, "max": 10 } }, "expectCall": { "domain": "number", "service": "set_value", "service_data": { "entity_id": "number.x", "value": 6 } } },
    { "name": "input_number up by fractional step", "method": "adjustNumber", "args": ["input_number.x", 1], "entity": { "entity_id": "input_number.x", "state": "5", "attributes": { "step": 0.5 } }, "expectCall": { "domain": "input_number", "service": "set_value", "service_data": { "entity_id": "input_number.x", "value": 5.5 } } },
    { "name": "number clamps to max", "method": "adjustNumber", "args": ["number.x", 1], "entity": { "entity_id": "number.x", "state": "10", "attributes": { "step": 1, "min": 0, "max": 10 } }, "expectCall": { "domain": "number", "service": "set_value", "service_data": { "entity_id": "number.x", "value": 10 } } },
    { "name": "number clamps to min", "method": "adjustNumber", "args": ["number.x", -1], "entity": { "entity_id": "number.x", "state": "0", "attributes": { "step": 1, "min": 0, "max": 10 } }, "expectCall": { "domain": "number", "service": "set_value", "service_data": { "entity_id": "number.x", "value": 0 } } },
    { "name": "number missing entity is no-op", "method": "adjustNumber", "args": ["number.missing", 1], "expectCall": null },

    { "name": "select next option", "method": "cycleSelectOption", "args": ["select.x", 1], "entity": { "entity_id": "select.x", "state": "a", "attributes": { "options": ["a", "b", "c"] } }, "expectCall": { "domain": "select", "service": "select_option", "service_data": { "entity_id": "select.x", "option": "b" } } },
    { "name": "select next wraps c -> a", "method": "cycleSelectOption", "args": ["select.x", 1], "entity": { "entity_id": "select.x", "state": "c", "attributes": { "options": ["a", "b", "c"] } }, "expectCall": { "domain": "select", "service": "select_option", "service_data": { "entity_id": "select.x", "option": "a" } } },
    { "name": "select previous wraps a -> c", "method": "cycleSelectOption", "args": ["select.x", -1], "entity": { "entity_id": "select.x", "state": "a", "attributes": { "options": ["a", "b", "c"] } }, "expectCall": { "domain": "select", "service": "select_option", "service_data": { "entity_id": "select.x", "option": "c" } } },
    { "name": "input_select next option", "method": "cycleSelectOption", "args": ["input_select.x", 1], "entity": { "entity_id": "input_select.x", "state": "x", "attributes": { "options": ["x", "y"] } }, "expectCall": { "domain": "input_select", "service": "select_option", "service_data": { "entity_id": "input_select.x", "option": "y" } } },
    { "name": "select single option is no-op", "method": "cycleSelectOption", "args": ["select.x", 1], "entity": { "entity_id": "select.x", "state": "only", "attributes": { "options": ["only"] } }, "expectCall": null },

    { "name": "bulk power on groups by domain", "method": "bulkPower", "args": [["light.a", "light.b", "switch.c"], "on"], "expectCalls": [ { "domain": "light", "service": "turn_on", "service_data": { "entity_id": ["light.a", "light.b"] } }, { "domain": "switch", "service": "turn_on", "service_data": { "entity_id": ["switch.c"] } } ] },
    { "name": "bulk power off", "method": "bulkPower", "args": [["light.a"], "off"], "expectCalls": [ { "domain": "light", "service": "turn_off", "service_data": { "entity_id": ["light.a"] } } ] },
    { "name": "bulk cover on uses open_cover", "method": "bulkPower", "args": [["cover.a"], "on"], "expectCalls": [ { "domain": "cover", "service": "open_cover", "service_data": { "entity_id": ["cover.a"] } } ] },
    { "name": "bulk cover off uses close_cover", "method": "bulkPower", "args": [["cover.a"], "off"], "expectCalls": [ { "domain": "cover", "service": "close_cover", "service_data": { "entity_id": ["cover.a"] } } ] },
    { "name": "bulk power ignores unsupported domains", "method": "bulkPower", "args": [["sensor.a"], "on"], "expectCalls": [] }
  ]
}
